{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "node .cursor/hooks/secdevops-guardrails.mjs",
        "matcher": "Shell|Read|Write|Delete|StrReplace",
        "failClosed": false
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/secdevops-guardrails.mjs",
        "failClosed": false
      }
    ],
    "beforeReadFile": [
      {
        "command": "node .cursor/hooks/secdevops-guardrails.mjs",
        "failClosed": true
      }
    ]
  }
}
